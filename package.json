{
  "name": "epr-re-ex-service",
  "version": "0.0.0",
  "description": "pEPR Re/Ex project",
  "engines": {
    "node": "^24.18.0"
  },
  "scripts": {
    "dev": "GOVUK_NOTIFY_API_KEY=test-api-key-12345 docker compose --profile all up --watch",
    "dev:env": "npx @dotenvx/dotenvx run -- docker compose --profile all up --watch",
    "adr:generate:toc": "adr generate toc > ./docs/architecture/decisions/index.md",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\"",
    "lint:types": "tsc -p jsconfig.typecheck.json",
    "postinstall": "npm run setup:husky",
    "seed:stub": "node scripts/seed-defra-id-stub.mjs",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module",
    "test": "vitest run",
    "validate:renovate": "renovate-config-validator --strict renovate.json renovate-presets/default.json renovate-presets/defra-node.json"
  },
  "author": "Defra DDTS",
  "license": "OGL-UK-3.0",
  "overrides": {},
  "devDependencies": {
    "@dotenvx/dotenvx": "2.15.1",
    "@types/node": "26.1.1",
    "husky": "9.1.7",
    "lint-staged": "17.1.0",
    "mongodb": "7.5.0",
    "prettier": "3.9.5",
    "renovate": "43.272.6",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
