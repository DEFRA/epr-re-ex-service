{
  "name": "OAuth2 - Mock Token Endpoint",
  "request": {
    "method": "POST",
    "urlPath": "/forms-submission-api/oauth2/token",
    "headers": {
      "Content-Type": {
        "equalTo": "application/x-www-form-urlencoded"
      }
    },
    "bodyPatterns": [
      {
        "equalTo": "grant_type=client_credentials"
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "access_token": "mock-access-token-123",
      "token_type": "Bearer",
      "expires_in": 3600
    }
  }
}
