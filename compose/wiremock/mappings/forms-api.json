{
  "mappings": [
    {
      "name": "OAuth2 - Mock Token Endpoint",
      "request": {
        "method": "POST",
        "urlPath": "/oauth2/token",
        "headers": {
          "Content-Type": {
            "equalTo": "application/x-www-form-urlencoded"
          }
        },
        "bodyPatterns": [
          {
            "equalTo": "grant_type=client_credentials"
          }
        ]
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "jsonBody": {
          "access_token": "mock-access-token-123",
          "token_type": "Bearer",
          "expires_in": 3600
        }
      }
    },
    {
      "name": "Forms Submission API - Get File Link",
      "request": {
        "method": "POST",
        "urlPath": "/file/link",
        "headers": {
          "Authorization": {
            "matches": "Bearer .*"
          }
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "jsonBody": {
          "url": "http://localstack:4566/re-ex-form-uploads/defra-forms-stub/test-file-001.txt",
          "expiresAt": "{{now offset='1 days' format='yyyy-MM-dd HH:mm:ss'}}"
        },
        "transformers": ["response-template"]
      }
    },
    {
      "name": "Forms Submission API - Health Check",
      "request": {
        "method": "GET",
        "urlPath": "/health"
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "jsonBody": {
          "status": "ok",
          "service": "forms-submission-api-wiremock"
        }
      }
    }
  ]
}
