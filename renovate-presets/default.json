{
  "minimumReleaseAge": "3 days",
  "recreateWhen": "always",
  "commitMessagePrefix": "Renovate:",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)package\\.json$/"],
      "matchStrings": ["\"node\":\\s*\">=(?<currentValue>\\d+\\.\\d+\\.\\d+)"],
      "depNameTemplate": "node",
      "datasourceTemplate": "node-version",
      "versioningTemplate": "node"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["docker-compose"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "docker compose images"
    },
    {
      "matchDatasources": ["docker", "node-version"],
      "matchPackageNames": ["node"],
      "allowedVersions": "<25"
    },
    {
      "matchDatasources": ["docker", "node-version"],
      "matchPackageNames": [
        "/(?:^|/)node$/",
        "!defradigital/node",
        "!calico/node",
        "!docker.io/calico/node",
        "!ghcr.io/devcontainers/features/node",
        "!kindest/node"
      ],
      "groupName": "Node.js"
    },
    {
      "matchDatasources": ["node-version"],
      "matchPackageNames": ["node"],
      "postUpgradeTasks": {
        "commands": [
          "install-tool node",
          "npm install --package-lock-only --ignore-scripts"
        ],
        "fileFilters": ["package-lock.json"],
        "executionMode": "branch"
      }
    },
    {
      "description": "Exempt the official node base image from minimumReleaseAge so the Dockerfile bumps in lockstep with the node-version files; the node-version datasource already enforces 3-day maturity on the release, and frequent Alpine image rebuilds would otherwise re-trigger cooldown and split the Node.js group into broken half-updates",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["node"],
      "minimumReleaseAge": "0 days"
    }
  ]
}
