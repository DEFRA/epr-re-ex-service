{
  "minimumReleaseAge": "3 days",
  "recreateWhen": "always",
  "commitMessagePrefix": "Renovate:",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)package\\.json$/"
      ],
      "matchStrings": [
        "\"node\":\\s*\">=(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "node",
      "datasourceTemplate": "node-version",
      "versioningTemplate": "node"
    }
  ],
  "packageRules": [
    {
      "matchManagers": [
        "docker-compose"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "docker compose images"
    },
    {
      "matchDatasources": [
        "docker",
        "node-version"
      ],
      "matchPackageNames": [
        "node"
      ],
      "allowedVersions": "<25"
    },
    {
      "matchDatasources": [
        "docker",
        "node-version"
      ],
      "matchPackageNames": [
        "/(?:^|/)node$/",
        "!defradigital/node",
        "!calico/node",
        "!docker.io/calico/node",
        "!ghcr.io/devcontainers/features/node",
        "!kindest/node"
      ],
      "groupName": "Node.js"
    },
    {
      "matchDatasources": [
        "node-version"
      ],
      "matchPackageNames": [
        "node"
      ],
      "postUpgradeTasks": {
        "commands": [
          "install-tool node",
          "npm install --package-lock-only --ignore-scripts"
        ],
        "fileFilters": [
          "package-lock.json"
        ],
        "executionMode": "branch"
      }
    },
    {
      "description": "Manage the official node base image: exempt it from minimumReleaseAge so it bumps in lockstep with the node-version files (the node-version datasource already enforces 3-day maturity on the release), and pin the image digest so the exact image is locked and every node/alpine/digest change arrives as a reviewable PR",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "node"
      ],
      "minimumReleaseAge": "0 days",
      "pinDigests": true
    }
  ]
}
